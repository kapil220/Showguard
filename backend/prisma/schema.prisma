// ShowGuard data model — Wave 1.0 core.
// Outcome capture (Appointment + Outcome) is the one hidden non-negotiable:
// it must be clean and labelled from the first live appointment, since it's
// the training data Version 2's ML model depends on.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RiskLevel {
  GREEN
  YELLOW
  RED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  AT_RISK
  RESCHEDULED
  CANCELLED
  SHOWED
  NO_SHOW
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageChannel {
  SMS
  VOICE_CALL
}

// A contractor account connected via GoHighLevel. Also the future
// Version 3 white-label tenant boundary.
model Client {
  id            String        @id @default(cuid())
  name          String
  timezone      String
  ghlLocationId String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  contacts      Contact[]
  appointments  Appointment[]
}

// The homeowner / lead tied to an appointment.
model Contact {
  id           String        @id @default(cuid())
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id])
  name         String
  phone        String
  optedOut     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  appointments Appointment[]
  messages     Message[]

  @@index([clientId, phone])
}

// One booked appointment, ingested from GoHighLevel.
model Appointment {
  id               String            @id @default(cuid())
  clientId         String
  client           Client            @relation(fields: [clientId], references: [id])
  contactId        String
  contact          Contact           @relation(fields: [contactId], references: [id])
  ghlAppointmentId String            @unique
  scheduledAt      DateTime
  status           AppointmentStatus @default(SCHEDULED)
  riskLevel        RiskLevel?
  riskScoredAt     DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  messages         Message[]
  outcome          Outcome?

  @@index([clientId, scheduledAt])
  @@index([riskLevel])
}

// Every inbound/outbound touch — the confirm sequence, replies, rescue
// attempts, nurture messages, and any AI voice calls.
model Message {
  id            String           @id @default(cuid())
  appointmentId String
  appointment   Appointment      @relation(fields: [appointmentId], references: [id])
  contactId     String
  contact       Contact          @relation(fields: [contactId], references: [id])
  direction     MessageDirection
  channel       MessageChannel   @default(SMS)
  body          String
  sentAt        DateTime         @default(now())

  @@index([appointmentId])
}

// The ground-truth "what happened" record. This is the ML foundation —
// get this schema right now (see header note).
model Outcome {
  id              String      @id @default(cuid())
  appointmentId   String      @unique
  appointment     Appointment @relation(fields: [appointmentId], references: [id])
  showed          Boolean
  cancelledAt     DateTime?
  rescueAttempted Boolean     @default(false)
  rescueSucceeded Boolean?
  notes           String?
  recordedAt      DateTime    @default(now())
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String    @map("password_hash")
  resetTokenHash      String?   @map("reset_token_hash")
  resetTokenExpiresAt DateTime? @map("reset_token_expires_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@map("users")
}

